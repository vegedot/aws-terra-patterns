aws_region  = "ap-northeast-1"
project     = "my-project"
environment = "dev"

# Networking
vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.0.0/24", "10.0.1.0/24"]
private_subnet_cidrs = ["10.0.10.0/24", "10.0.11.0/24"]
db_subnet_cidrs      = ["10.0.20.0/24", "10.0.21.0/24"]

# Bastion (Linux SSM + Windows SSM)
windows_bastion_instance_type = "t3.medium"

# ECS
app_image_tag     = "latest"
app_port          = 8080
app_cpu           = 512
app_memory        = 1024
app_desired_count = 1

efs_container_path = "/mnt/efs"

# <TASKID> は起動時にタスク ID に置換される（複数パス指定可）
efs_log_paths = [
  "/mnt/efs/logs/<TASKID>/*.log",
  # "/mnt/efs/audit/<TASKID>/*.log",
]

# ALB スティッキーセッション: アプリが Set-Cookie で発行する Cookie 名と一致させること
alb_sticky_session_cookie_name = "JSESSIONID"

# ヘルスチェックパス: Tomcat HealthCheckValve のパスと一致させること
health_check_path = "/health-check"

# Oracle RDS
# 利用可能なバージョンは以下で確認:
#   aws rds describe-db-engine-versions --engine oracle-se2 --query 'DBEngineVersions[*].EngineVersion'
db_name              = "ORCL"
db_master_username   = "dbadmin"
db_engine_version    = "19.0.0.0.ru-2025-01.rur-2025-01.r1"
db_instance_class    = "db.t3.medium"
db_allocated_storage = 20
